# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# --- JWT ---
# 32+ chars 隨機字串。production 走 secret manager。
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# FE 可選：publishable key，留空走 demo 模式
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# FE 可選：公開 client ID，留空走 demo 模式（msw 接受任意 id_token）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3001

# --- Observability ---
# 留空表示不啟用 Sentry（本機開發可不填）
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
